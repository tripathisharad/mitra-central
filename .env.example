# ===== App =====
APP_NAME="Mitra Central"
APP_SECRET_KEY="change-me-in-production-please"
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ===== Hardcoded auth (Phase 1) =====
AUTH_USERNAME=admin
AUTH_PASSWORD=mfgpro

# ===== Session =====
SESSION_COOKIE_NAME=mitra_session
SESSION_TTL_SECONDS=28800

# ===== QAD =====
QAD_DOMAIN=INDIA
DEFAULT_ROW_LIMIT=50

# ===== QAD / Progress ODBC =====
ODBC_DSN=QAD_PROGRESS
ODBC_USER=
ODBC_PASSWORD=
ODBC_CONNECTION_STRING=

# ===== OpenAI (quality tasks: SQL gen, RAG answers, doc gen) =====
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-large

# ===== Groq (free/fast: classification, table-ID, routing) =====
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ===== Qdrant =====
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_APEX=apex-normal
